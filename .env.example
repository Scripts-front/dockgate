# DockGate — required environment variables
# Copy this file to .env and fill in real values

# Authentication tokens — set to long random strings
DOWNLOAD_TOKEN=changeme-download-token
UPLOAD_TOKEN=changeme-upload-token

# MinIO connectivity
# MINIO_ENDPOINT: hostname only (no http://) — Docker service name or IP
MINIO_ENDPOINT=minio
# MINIO_PUBLIC_ENDPOINT: full URL clients use to access presigned URLs
MINIO_PUBLIC_ENDPOINT=http://192.168.1.10:9000
MINIO_BUCKET=dockgate
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Optional: use SSL for MinIO connection (auto-detected if port=443, default: false)
# MINIO_USE_SSL=false

# Optional: HTTP port (default: 3000)
# PORT=3000
